# Copy to .env and edit as needed.
# All paths are auto-detected from src/dcfaces/paths.py — no path configuration needed here.

# HuggingFace token (only required if you need gated models — most aren't)
HF_TOKEN=

# Which GPU device to use (single-GPU pipeline)
CUDA_VISIBLE_DEVICES=0

# Wandb tracking (optional — set MODE=offline to disable)
WANDB_PROJECT=dcfaces
WANDB_MODE=online
WANDB_API_KEY=
