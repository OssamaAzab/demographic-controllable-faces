# Data, models, results — too large for GitHub, regenerated by the pipeline
data/*
!data/.gitkeep
!data/identity_gallery/.gitkeep
models/*
!models/.gitkeep
results/*
!results/.gitkeep
# track the small proof artifacts, not the heavy generations
!results/*.csv
!results/*.json
!results/tables/
!results/figures/
results/figures/*
!results/figures/*.png

# benchmark: track the per-image scores + manifest (lets aggregation rerun without
# regenerating the 13 GB of images), but not the generations themselves
!results/benchmark/
results/benchmark/*
!results/benchmark/*.jsonl
!results/benchmark/*.json

# curated sample gallery (small visual evidence; full image set regenerated by pipeline)
!results/samples/
!results/samples/**

# full browsable gallery: one 512px preview per method/identity/prompt (~90 MB);
# the full-resolution generations stay gitignored
!results/gallery/
!results/gallery/**
.cache/
*.safetensors
*.bin
*.pt
*.ckpt
*.onnx

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Environments
.env
.venv/
venv/
env/
ENV/

# Notebooks
.ipynb_checkpoints/

# local LoRA test bench (not for the repo)
notebooks/test_lora.ipynb
notebooks/test_dreambooth.ipynb
notebooks/test_output.png
db_test*.png

# Logs / tracking
wandb/
tensorboard/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# local-only assistant context file
CLAUDE.md

# vendored NVlabs FFHQ downloader (CC-BY-NC-SA) - kept local, not redistributed
scripts/download_ffhq.py

# external method repos (PuLID, HyperLoRA, ...) - cloned locally, imported not vendored
external/

# throwaway smoke-test / download helper scripts (superseded by scripts/00_fetch_weights.py)
smoke_*.py
dl_*.py
sweep_*.py
notebooks/test_*.ipynb

# stray local artifacts
.hf_cache/
db_*.png
color_test.py
.venv-mivolo/
