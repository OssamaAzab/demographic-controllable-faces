# Data, models, results — too large for GitHub, regenerated by the pipeline
data/*
!data/.gitkeep
!data/identity_gallery/.gitkeep
models/*
!models/.gitkeep
results/*
!results/.gitkeep
# track the small proof artifacts, not the heavy generations
!results/*.csv
!results/*.json
!results/tables/
!results/figures/
results/figures/*
!results/figures/*.png
.cache/
*.safetensors
*.bin
*.pt
*.ckpt
*.onnx

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Environments
.env
.venv/
venv/
env/
ENV/

# Notebooks
.ipynb_checkpoints/

# local LoRA test bench (not for the repo)
notebooks/test_lora.ipynb
notebooks/test_output.png

# Logs / tracking
wandb/
tensorboard/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

